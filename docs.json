{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Speko",
  "colors": {
    "primary": "#E8590C",
    "light": "#FF7A2E",
    "dark": "#C44A0A"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development",
              "playground-livekit"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "@spekoai/sdk",
            "pages": [
              "sdk/overview",
              "sdk/speko-client",
              "sdk/transcribe",
              "sdk/synthesize",
              "sdk/complete",
              "sdk/usage",
              "sdk/types",
              "sdk/errors"
            ]
          },
          {
            "group": "@spekoai/client",
            "pages": [
              "client/overview",
              "client/voice-conversation",
              "client/callbacks",
              "client/data-channel",
              "client/errors"
            ]
          },
          {
            "group": "@spekoai/adapter-livekit",
            "pages": [
              "adapter-livekit/overview",
              "adapter-livekit/create-speko-components",
              "adapter-livekit/speko-stt",
              "adapter-livekit/speko-llm",
              "adapter-livekit/speko-tts",
              "adapter-livekit/intent",
              "adapter-livekit/audio"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://speko.ai",
          "icon": "globe"
        },
        {
          "anchor": "Dashboard",
          "href": "https://speko.dev",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:abat@speko.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://speko.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/spekoai",
      "github": "https://github.com/SpekoAI",
      "linkedin": "https://www.linkedin.com/company/spekoai"
    }
  }
}
